# ============================================================================
# PlaceBot configuration
#
# Copy this file to ".env" and adjust values as needed:
#   cp .env.example .env
#
# Every variable is optional - if a variable is missing, the default shown
# below is used. The ".env" file is gitignored, so your local settings
# (and anything sensitive you add later) won't be committed.
# ============================================================================

# --- Ollama (optional local LLM) -------------------------------------------
# Set to "false" to run PlaceBot in dataset-only mode without Ollama.
OLLAMA_ENABLED=true
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=llama3.2
# Seconds to wait for an Ollama response before falling back.
OLLAMA_TIMEOUT=30

# --- Hybrid response confidence thresholds (0.0 - 1.0) ----------------------
#   score >= HIGH_CONFIDENCE          -> answer directly from the dataset
#   MEDIUM_CONFIDENCE <= score < HIGH -> ask Ollama, using the dataset answer
#                                         as context
#   score <  MEDIUM_CONFIDENCE        -> ask Ollama with no context, or fall
#                                         back to a generic message
HIGH_CONFIDENCE=0.5
MEDIUM_CONFIDENCE=0.3

# --- Dataset & embedding model -----------------------------------------------
CSV_FILE=data.csv
EMBEDDING_MODEL=all-MiniLM-L6-v2

# --- Server / browser ---------------------------------------------------------
HOST=127.0.0.1
PORT=8000
# Automatically open the chat UI in your browser on startup.
# Set to "false" on servers / in CI, where there's no browser to open.
AUTO_OPEN_BROWSER=true
